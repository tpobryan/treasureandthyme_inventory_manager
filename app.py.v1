import base64
import csv
import json
import os
import threading
import uuid
from pathlib import Path
from typing import List

from dotenv import load_dotenv
from flask import Flask, redirect, render_template, request, url_for, flash
from openai import OpenAI
from werkzeug.utils import secure_filename

load_dotenv()

BASE_DIR = Path(__file__).resolve().parent
UPLOAD_DIR = BASE_DIR / "uploads"
DATA_DIR = BASE_DIR / "data"
CSV_PATH = DATA_DIR / "auction_items.csv"
STATE_PATH = DATA_DIR / "lot_state.json"
ALLOWED_EXTENSIONS = {".jpg", ".jpeg", ".png", ".webp", ".heic", ".heif"}
LOCK = threading.Lock()

CSV_HEADER = [
    "Lot Number",
    "Lead",
    "Description",
    "Condition notes",
    "Low Estimate ($)",
    "High Estimate ($)",
    "Dimensions - Length",
    "Dimensions - Depth",
    "Dimensions - Height",
    "Tags",
    "Reference #",
    "Item Notes",
    "Consigner #",
    "Shipping Available",
    "Category",
]

DEFAULT_CATEGORIES = [
    "Jewelry",
    "Fashion Accessories",
    "Pottery & Glass",
    "Decorative Arts",
    "Collectibles",
    "Art",
    "Books & Ephemera",
    "Religious",
    "Household",
    "Toys",
    "Other",
]

app = Flask(__name__)
app.secret_key = os.getenv("FLASK_SECRET_KEY", "dev-secret-change-me")
app.config["MAX_CONTENT_LENGTH"] = 40 * 1024 * 1024  # 40 MB total request size

UPLOAD_DIR.mkdir(parents=True, exist_ok=True)
DATA_DIR.mkdir(parents=True, exist_ok=True)
if not STATE_PATH.exists():
    STATE_PATH.write_text(json.dumps({"last_lot": 1999}, indent=2))


def get_openai_client() -> OpenAI:
    api_key = os.getenv("OPENAI_API_KEY")
    if not api_key:
        raise RuntimeError("OPENAI_API_KEY is missing. Add it to your .env file.")
    return OpenAI(api_key=api_key)


def allowed_file(filename: str) -> bool:
    return Path(filename).suffix.lower() in ALLOWED_EXTENSIONS


def save_uploaded_files(files) -> tuple[str, List[Path]]:
    temp_id = str(uuid.uuid4())
    temp_dir = UPLOAD_DIR / temp_id
    temp_dir.mkdir(parents=True, exist_ok=True)
    saved_files: List[Path] = []

    for file_storage in files:
        if not file_storage or not file_storage.filename:
            continue
        filename = secure_filename(file_storage.filename)
        if not filename:
            continue
        if not allowed_file(filename):
            continue
        dest = temp_dir / filename
        file_storage.save(dest)
        saved_files.append(dest)

    return temp_id, saved_files


def encode_image_data_url(path: Path) -> str:
    ext = path.suffix.lower().replace(".", "")
    if ext == "jpg":
        ext = "jpeg"
    if ext in {"heic", "heif"}:
        # Browsers on iOS may upload HEIC/HEIF. Many backends can still store it,
        # but the data URL should use a standard image mime type only if supported.
        # The model may still process it when presented as octet-stream, but to keep
        # this app simple and predictable, instruct users to use JPG/PNG if needed.
        mime = "image/heic"
    else:
        mime = f"image/{ext}"

    encoded = base64.b64encode(path.read_bytes()).decode("utf-8")
    return f"data:{mime};base64,{encoded}"


def analyze_images(image_paths: List[Path]) -> dict:
    client = get_openai_client()
    content = [
        {
            "type": "input_text",
            "text": (
                "Identify the item in the photos and generate an auction listing.\n\n"
                "TITLE RULES\n"
                "- Clear SEO title\n"
                "- Include material, item type, and notable feature if visible\n"
                "- Avoid marketing words like beautiful, stunning, gorgeous\n\n"
                "DESCRIPTION RULES\n"
                "- Short and factual\n"
                "- 1 to 2 sentences maximum\n"
                "- State what the item is\n"
                "- Mention material, markings, or notable feature if visible\n"
                "- No flowery language\n\n"
                "TAGS\n"
                "- 6 to 10 comma-separated SEO tags\n\n"
                "CATEGORY\n"
                "- Choose the single best broad auction category\n\n"
                "Return JSON only with keys: title, description, tags, category"
            ),
        }
    ]

    for image_path in image_paths:
        content.append(
            {
                "type": "input_image",
                "image_url": encode_image_data_url(image_path),
            }
        )

    response = client.responses.create(
        model=os.getenv("OPENAI_MODEL", "gpt-4.1-mini"),
        input=[{"role": "user", "content": content}],
    )

    text = response.output_text.strip()
    try:
        data = json.loads(text)
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"Could not parse model response as JSON: {text}") from exc

    return {
        "title": str(data.get("title", "")).strip(),
        "description": str(data.get("description", "")).strip(),
        "tags": str(data.get("tags", "")).strip(),
        "category": str(data.get("category", "")).strip(),
    }


def get_next_lot_preview() -> int:
    state = json.loads(STATE_PATH.read_text())
    return int(state.get("last_lot", 1999)) + 1


def allocate_next_lot() -> int:
    with LOCK:
        state = json.loads(STATE_PATH.read_text())
        last_lot = int(state.get("last_lot", 1999))
        next_lot = last_lot + 1
        state["last_lot"] = next_lot
        STATE_PATH.write_text(json.dumps(state, indent=2))
        return next_lot


def append_csv_row(row: dict) -> None:
    file_exists = CSV_PATH.exists()
    with LOCK:
        with CSV_PATH.open("a", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=CSV_HEADER)
            if not file_exists:
                writer.writeheader()
            writer.writerow(row)


@app.route("/", methods=["GET"])
def index():
    return render_template(
        "index.html",
        next_lot=get_next_lot_preview(),
        categories=DEFAULT_CATEGORIES,
    )


@app.route("/analyze", methods=["POST"])
def analyze():
    uploaded_files = request.files.getlist("photos")
    temp_id, saved_files = save_uploaded_files(uploaded_files)

    if not saved_files:
        flash("Please choose at least one JPG, PNG, WebP, or HEIC image.")
        return redirect(url_for("index"))

    try:
        ai_data = analyze_images(saved_files)
    except Exception as exc:
        flash(f"AI analysis failed: {exc}")
        return redirect(url_for("index"))

    return render_template(
        "edit.html",
        temp_id=temp_id,
        image_files=[p.name for p in saved_files],
        image_url_prefix=f"/uploads/{temp_id}/",
        next_lot=get_next_lot_preview(),
        categories=DEFAULT_CATEGORIES,
        form={
            "Lead": ai_data["title"],
            "Description": ai_data["description"],
            "Condition notes": "",
            "Low Estimate ($)": "",
            "High Estimate ($)": "",
            "Dimensions - Length": "",
            "Dimensions - Depth": "",
            "Dimensions - Height": "",
            "Tags": ai_data["tags"],
            "Reference #": "",
            "Item Notes": "",
            "Consigner #": "",
            "Shipping Available": "",
            "Category": ai_data["category"] or "Other",
        },
    )


@app.route("/save", methods=["POST"])
def save():
    lot_number = allocate_next_lot()
    row = {column: request.form.get(column, "").strip() for column in CSV_HEADER if column != "Lot Number"}
    row["Lot Number"] = lot_number
    append_csv_row(row)

    temp_id = request.form.get("temp_id", "")
    temp_dir = UPLOAD_DIR / temp_id
    if temp_dir.exists():
        for child in temp_dir.iterdir():
            try:
                child.unlink()
            except OSError:
                pass
        try:
            temp_dir.rmdir()
        except OSError:
            pass

    return render_template("saved.html", lot_number=lot_number, row=row)


@app.route("/uploads/<temp_id>/<filename>")
def uploaded_file(temp_id: str, filename: str):
    from flask import send_from_directory

    return send_from_directory(UPLOAD_DIR / temp_id, filename)


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=int(os.getenv("PORT", "5000")), debug=False)
